# GitLab host (EC2のパブリックIPまたはドメイン名)
GITLAB_HOST=your-ec2-ip

# GitLab Bot UserのPersonal Access Token (api scope)
# GitLab > User Settings > Access Tokens で発行
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Webhook検証用シークレット (任意の文字列)
# GitLab > Settings > Webhooks の Secret Token と一致させる
WEBHOOK_SECRET=your-webhook-secret

# Pipeline Trigger Token
# GitLab > Settings > CI/CD > Pipeline triggers で発行
TRIGGER_TOKEN=your-trigger-token

# 対象プロジェクトのID
# GitLab > Project > Settings > General > Project ID で確認
GITLAB_PROJECT_ID=1

# Bot UserのID (無限ループ防止)
# GitLab API: GET /users?username=<bot-username> で確認
BOT_USER_ID=2

# GitLabのAPI URL (docker-compose内からはサービス名で参照)
GITLAB_URL=http://gitlab
